# Ignore Python cache
__pycache__/
*.py[cod]
*$py.class

# Ignore virtual environment
venv/
.venv/


# Ignore IDE files
.idea/
.vscode/

# Ignore editor files
*~
*.swp
*.swo

# Ignore system files
.DS_Store
Thumbs.db

# Ignore temporary files
*.tmp
*.log
*.bak

# Ignore build artifacts
dist/
build/
*.egg-info/

# Ignore Python packaging files
*.pyc
*.pyo
*.pyd

